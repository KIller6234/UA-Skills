# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/nih

# Individual DB credentials (used by docker-compose to create the DB)
DB_NAME=nih
DB_USER=user
DB_PASSWORD=changeme_db_password

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis connection URL (must match REDIS_PASSWORD below)
REDIS_URL=redis://:changeme_redis@localhost:6379

# Redis password — also used in docker-compose redis command
REDIS_PASSWORD=changeme_redis

# Redis max memory allocation (BullMQ requires noeviction policy — set in docker-compose)
REDIS_MAX_MEMORY=256mb

# ─── Authentication ───────────────────────────────────────────────────────────
# JWT signing secret — minimum 32 characters, generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_char_minimum_secret_here

# Access token TTL in seconds (default: 15 minutes)
JWT_ACCESS_TTL=900

# Refresh token TTL in seconds (default: 7 days)
JWT_REFRESH_TTL=604800

# ─── LLM Providers ───────────────────────────────────────────────────────────
# Primary provider: openai | anthropic
LLM_PRIMARY_PROVIDER=openai

# Fallback provider (used when primary fails)
LLM_FALLBACK_PROVIDER=anthropic

# Model names — change to use different/cheaper models
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_ANTHROPIC=claude-haiku-4-5-20251001

# API keys — at least one is required
LLM_API_KEY_OPENAI=sk-...
LLM_API_KEY_ANTHROPIC=sk-ant-...

# Max parallel LLM calls (cost control)
LLM_CONCURRENCY=3

# Max input tokens per article (articles truncated to this limit before LLM call)
LLM_MAX_INPUT_TOKENS=2000

# Bump this version to invalidate the LLM cache (e.g. when changing prompts)
LLM_PROMPT_VERSION=v1

# ─── Feed Polling ─────────────────────────────────────────────────────────────
# Default polling interval in seconds (overridable per feed)
FEED_POLL_INTERVAL_SECONDS=3600

# Max concurrent feed fetch operations
FEED_MAX_CONCURRENT_POLLS=5

# HTTP timeout for feed fetching in milliseconds
FEED_FETCH_TIMEOUT_MS=10000

# Number of consecutive failures before marking feed as ERROR
FEED_MAX_FAILURES_BEFORE_ERROR=5

# ─── Article Pre-filter ───────────────────────────────────────────────────────
# Articles with fewer words are discarded without calling LLM
PREFILTER_MIN_WORD_COUNT=50

# Articles with shorter extracted body are discarded
PREFILTER_MIN_BODY_LENGTH=200

# ─── Workers ──────────────────────────────────────────────────────────────────
# Number of worker process replicas (docker-compose deploy.replicas)
WORKER_REPLICAS=1

# ─── Bull Board (Queue Monitor) ───────────────────────────────────────────────
# Basic-auth credentials for http://localhost:3002
BULL_BOARD_USER=admin
BULL_BOARD_PASS=changeme_bull_password

# ─── Application ──────────────────────────────────────────────────────────────
# Frontend URL for CORS whitelist
FRONTEND_URL=http://localhost:3001

# Set to true to show Bull Board link in the UI (admin feature)
SHOW_BULL_BOARD_LINK=true

# Runtime environment
NODE_ENV=development

# API server port
PORT=3000
