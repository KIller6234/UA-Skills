{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "paths": {
      "@nih/config":   ["./libs/config/src/index.ts"],
      "@nih/database": ["./libs/database/src/index.ts"],
      "@nih/queues":   ["./libs/queues/src/index.ts"],
      "@nih/llm":      ["./libs/llm/src/index.ts"],
      "@nih/feed":     ["./libs/feed/src/index.ts"],
      "@nih/ner":      ["./libs/ner/src/index.ts"],
      "@nih/auth":     ["./libs/auth/src/index.ts"],
      "@nih/common":   ["./libs/common/src/index.ts"]
    }
  }
}
